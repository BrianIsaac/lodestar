# LLM — defaults work for local Ollama, override for DashScope
COACH_LLM_BASE_URL=http://localhost:11434/v1
COACH_LLM_MODEL=qwen3:14b
COACH_LLM_API_KEY=not-needed

# For Alibaba DashScope, use:
# COACH_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# COACH_LLM_MODEL=qwen-plus
# COACH_LLM_API_KEY=sk-xxxxx

# Backend
COACH_API_HOST=0.0.0.0
COACH_API_PORT=8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
